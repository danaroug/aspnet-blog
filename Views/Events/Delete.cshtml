@model WarbandOfTheSpiritborn.Models.Events

@{
    ViewData["Title"] = "Delete Event";
}

<nav class="navbar navbar-expand-lg bg-body-tertiary">
    <div class="container-fluid">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item d-flex align-items-center">
                    <a class="nav-link active" asp-controller="Home" asp-action="Index">Home</a>
                    <i class="bi bi-chevron-right"></i>
                </li>
                <li class="nav-item d-flex align-items-center">
                    <a class="nav-link" asp-action="Index">Events</a>
                    <i class="bi bi-chevron-right"></i>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="main-container">
    <div class="container">
        <h1>Delete Event</h1>
        <h3>Are you sure you want to delete @Html.DisplayFor(model => model.EventName)?</h3>
        <hr />
    </div>

    <div class="container">
        <dl class="row">
            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.EventName)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.EventName)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.EventInfo)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.EventInfo)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Time)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Time)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Date)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Date)</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-link">Back to Events</a>
        </form>
    </div>
</div>
        
    
