@{
    ViewData["Title"] = "Warband of the Spiritborn";
}

<section class="container text-center py-5">
    <div class="mx-auto" style="max-width: 720px;">
        <span class="text-uppercase small text-muted d-inline-block mb-3">Guild Wars 2 community hub</span>

        <h1 class="display-5 fw-semibold mb-3">Warband of the Spiritborn</h1>

        <p class="lead mb-3">
            A community space for Guild Wars 2 players to explore builds, improve their play, and share ideas across every profession.
        </p>

        <p class="text-muted mb-4">
            Browse curated builds, discover practical guidance, and connect with players who enjoy learning, refining strategies, and tackling content together.
        </p>

        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
            <a asp-controller="Builds" asp-action="Index" class="btn btn-dark px-4 py-2">
                Browse Builds
            </a>

            <a asp-controller="Blogs" asp-action="Index" class="btn btn-outline-secondary px-4 py-2">
                Read Blog Posts
            </a>
        </div>
    </div>
</section>
