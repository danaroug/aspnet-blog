@model WarbandOfTheSpiritborn.Models.About

@{
    ViewData["Title"] = "Delete About Content";
}

<partial name="_HelperNav" model='"About"' />

<div class="main-container">
    <div class="container-fluid">
        <section class="mb-4">
            <h1>Delete About Content</h1>
            <p class="text-muted">
                Are you sure you want to delete this About page section?
            </p>
        </section>

        <article class="about-delete-card mb-4">
            <h2>@Html.DisplayFor(model => model.AboutTitle)</h2>

            <div class="about-rich-content">
                @Html.Raw(Model.AboutText)
            </div>
        </article>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-2">
                <input type="submit" value="Delete" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>
        </form>
    </div>
</div>

<style>
    .about-delete-card {
        padding: 1.5rem;
        border-radius: 0.75rem;
        background: rgba(255, 255, 255, 0.03);
    }

    .about-rich-content p:last-child {
        margin-bottom: 0;
    }

    .about-rich-content blockquote {
        padding-left: 1rem;
        border-left: 4px solid currentColor;
        opacity: 0.85;
    }
</style>
