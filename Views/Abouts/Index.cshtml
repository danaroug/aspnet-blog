@model IEnumerable<WarbandOfTheSpiritborn.Models.About>

@{
    ViewData["Title"] = "About";
    var canManageAbout = User.IsInRole("Moderator") || User.IsInRole("Administrator");
}

<partial name="_HelperNav" model='"About"' />

<div class="main-container">
    <div class="container-fluid">
        <section class="mb-4">
            <h1>Discover our story</h1>
            <p class="text-muted">
                Learn more about Warband of the Spiritborn, the project, and what users can explore.
            </p>

            @if (canManageAbout)
            {
                <a asp-action="Create" class="btn btn-primary btn-dark">
                    Add Content
                </a>
            }
        </section>

        <hr />

        @if (!Model.Any())
        {
            <section class="about-content-card">
                <h2>No About content yet</h2>
                <p>
                    About page content has not been added yet.
                </p>
            </section>
        }
        else
        {
            foreach (var item in Model)
            {
                <article class="about-content-card mb-4">
                    <h2>@Html.DisplayFor(modelItem => item.AboutTitle)</h2>

                    <div class="about-rich-content">
                        @Html.Raw(item.AboutText)
                    </div>

                    @if (canManageAbout)
                    {
                        <div class="mt-3 d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                Edit
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>
                        </div>
                    }
                </article>
            }
        }
    </div>
</div>