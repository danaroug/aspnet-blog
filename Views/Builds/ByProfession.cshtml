@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model IEnumerable<WarbandOfTheSpiritborn.Models.Builds>

@{
    ViewData["Title"] = "Elementalist Builds";
    var profession = ViewData["Profession"] as string ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<nav class="navbar navbar-expand-lg bg-body-tertiary">
    <div class="container-fluid">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item d-flex align-items-center">
                    <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">Home</a>
                    <i class="bi bi-chevron-right"></i>
                </li>
                <li class="nav-item d-flex align-items-center">
                    <a class="nav-link @(currentController == "Builds" && currentAction == "Index" ? "active" : "")"
                       asp-controller="Builds" asp-action="Index">Builds</a>
                    <i class="bi bi-chevron-right"></i>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(profession == "Elementalist" ? "active" : "")"
                       asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Elementalist">
                        Elementalist
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container">
    <h1>@profession Builds</h1>
    <p>Below you can find all the @profession builds.</p>
    <hr />
</div>

<div class="container-fluid">
    @if (!Model.Any())
    {
        <p>No Elementalist builds found.</p>
    }
    else
    {
        foreach (var item in Model)
        {
            <h3>@Html.DisplayFor(modelItem => item.BuildName)</h3>
            <p>@Html.DisplayFor(modelItem => item.ShortDescription)</p>
            <p>Author: @Html.DisplayFor(modelItem => item.BuildAuthor)</p>
            <p>Posted: @item.BuildDate.ToString("MMMM dd, yyyy")</p>

            <p>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </p>
            <hr />
        }
    }
</div>
