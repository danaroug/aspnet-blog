<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Warband of the Spiritborn</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-Zenh87qX5JnK2Jl0vWa8Ck2rdkQ2Bzep5IDxbcnCeuOxjzrPF/et3URy9Bv1WTRi"
          crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="app-body">
    <header class="site-header">
        <nav class="navbar navbar-expand-lg simple-nav">
            <div class="container-xl">
                <a class="navbar-brand d-flex align-items-center gap-3" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/pictures/WoTS-logo.jpg" alt="Warband of the Spiritborn logo" width="48" height="48" class="site-logo" />
                    <span class="brand-text d-none d-sm-inline">Warband of the Spiritborn</span>
                </a>

                <button class="navbar-toggler custom-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNav"
                        aria-controls="mainNav"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-3 mb-lg-0 align-items-lg-center">
                        @if (User.IsInRole("Administrator"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle app-nav-link"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    <i class="bi bi-shield-lock me-1"></i> Admin
                                </a>

                                <ul class="dropdown-menu">
                                    <li>
                                        <h6 class="dropdown-header">Administrator tools</h6>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Admin" asp-action="Users">
                                            <i class="bi bi-person-lines-fill me-2"></i> User Management
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-controller="Abouts" asp-action="Index">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-controller="Events" asp-action="Index">Events</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-controller="Galleries" asp-action="Index">Gallery</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-controller="Blogs" asp-action="Index">Blog</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle app-nav-link"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Builds
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="Index">All Builds</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Elementalist">Elementalist</a></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Engineer">Engineer</a></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Guardian">Guardian</a></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Mesmer">Mesmer</a></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Necromancer">Necromancer</a></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Ranger">Ranger</a></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Revenant">Revenant</a></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Thief">Thief</a></li>
                                <li><a class="dropdown-item" asp-controller="Builds" asp-action="ByProfession" asp-route-profession="Warrior">Warrior</a></li>
                            </ul>
                        </li>
                    </ul>

                    <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-3">
                        <form asp-controller="Events" asp-action="Index" method="get" class="event-search-form d-flex">
                            <input name="searchPhrase"
                                   class="form-control app-search-input"
                                   placeholder="Search events"
                                   value="@(Context.Request.Query["searchPhrase"])" />
                            <button type="submit" class="btn app-btn app-btn-primary">Search</button>
                        </form>

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-xl page-layout">
        <div class="glass-wrapper">
            <main role="main" class="main-container p-3 p-md-4 p-xl-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="site-footer simple-footer">
        <div class="container-xl footer-inner">
            <span>&copy; @DateTime.Now.Year Warband of the Spiritborn</span>
            <span class="footer-divider">•</span>
            <span>Danai Rougkeri</span>
            <span class="footer-divider">•</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-OERcA2EqjJCMA+/3y+gxIOqMEjwtxJY7qPCqsdltbNJuaOe923+mo//f6V8Qbsw3"
            crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
